{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Cassy Desktop Reset Sandbox Data",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "tooling/scripts/Invoke-DesktopSandbox.ps1",
                "-ResetDemo"
            ],
            "problemMatcher": []
        },
        {
            "label": "Cassy Desktop Run Sandbox",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "tooling/scripts/Invoke-DesktopSandbox.ps1"
            ],
            "problemMatcher": []
        },
        {
            "label": "Cassy Desktop Smoke Run",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "tooling/scripts/Invoke-DesktopSandbox.ps1",
                "-SmokeRun",
                "-DataRoot",
                "${workspaceFolder}\\.sandbox\\desktop-smoke"
            ],
            "problemMatcher": []
        },
        {
            "label": "Cassy Desktop Source Smoke",
            "type": "shell",
            "command": ".\\gradlew",
            "args": [
                "-Dcassy.data.dir=${workspaceFolder}\\.sandbox\\desktop-smoke",
                ":apps:desktop-pos:smokeRun",
                "--no-configuration-cache",
                "--console=plain"
            ],
            "problemMatcher": []
        },
        {
            "label": "Cassy Core Verify",
            "type": "shell",
            "command": ".\\gradlew",
            "args": [
                "build",
                "test",
                "detekt",
                ":apps:android-pos:lintDebug",
                "--no-configuration-cache",
                "--console=plain"
            ],
            "problemMatcher": []
        },
        {
            "label": "Cassy R3 Hardened Gate",
            "type": "shell",
            "command": ".\\gradlew",
            "args": [
                ":shared:kernel:allTests",
                ":shared:sales:desktopTest",
                ":shared:inventory:desktopTest",
                ":shared:inventory:verifyCommonMainInventoryDatabaseMigration",
                ":apps:desktop-pos:test",
                ":apps:desktop-pos:smokeRun",
                "--no-configuration-cache",
                "--console=plain"
            ],
            "problemMatcher": []
        },
        {
            "label": "Cassy Windows Package",
            "type": "shell",
            "command": ".\\gradlew",
            "args": [
                ":apps:desktop-pos:createDistributable",
                ":apps:desktop-pos:packageDistributionForCurrentOS",
                "--no-configuration-cache",
                "--console=plain"
            ],
            "problemMatcher": []
        },
        {
            "label": "Cassy Windows Distribution Smoke",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "tooling/scripts/Invoke-DesktopDistributionSmoke.ps1"
            ],
            "problemMatcher": []
        }
    ]
}
