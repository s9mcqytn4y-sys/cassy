CREATE INDEX IF NOT EXISTS StockLedger_product_timestamp_idx ON StockLedger(productId, timestamp DESC);
CREATE INDEX IF NOT EXISTS StockLedger_reference_idx ON StockLedger(referenceId);
CREATE INDEX IF NOT EXISTS StockLedger_terminal_timestamp_idx ON StockLedger(terminalId, timestamp DESC);
CREATE UNIQUE INDEX IF NOT EXISTS StockLedger_reference_product_type_uidx ON StockLedger(referenceId, productId, type) WHERE referenceId IS NOT NULL;
