upsertCategory:
INSERT OR REPLACE INTO ProductCategory(id, name, color)
VALUES (?, ?, ?);

-- Queries
insertProduct:
INSERT OR REPLACE INTO Product(id, categoryId, name, price, sku, imageUrl, isActive)
VALUES (?, ?, ?, ?, ?, ?, ?);

insertBarcode:
INSERT OR REPLACE INTO ProductBarcode(barcode, productId, type)
VALUES (?, ?, ?);

deleteBarcode:
DELETE FROM ProductBarcode
WHERE barcode = ?;

selectAllProducts:
SELECT * FROM Product
ORDER BY isActive DESC, name COLLATE NOCASE ASC;

getProductsByCategory:
SELECT * FROM Product
WHERE categoryId = ?
ORDER BY isActive DESC, name COLLATE NOCASE ASC;

searchProducts:
SELECT * FROM Product
WHERE name LIKE ('%' || ? || '%') OR sku LIKE ('%' || ? || '%')
ORDER BY isActive DESC, name COLLATE NOCASE ASC;

selectProductById:
SELECT * FROM Product
WHERE id = ?;

findProductByBarcode:
SELECT p.* FROM Product p
JOIN ProductBarcode pb ON p.id = pb.productId
WHERE pb.barcode = ?;

selectAllCategories:
SELECT * FROM ProductCategory
ORDER BY name COLLATE NOCASE ASC;

selectBarcodesByProduct:
SELECT * FROM ProductBarcode
WHERE productId = ?
ORDER BY type COLLATE NOCASE ASC, barcode COLLATE NOCASE ASC;
