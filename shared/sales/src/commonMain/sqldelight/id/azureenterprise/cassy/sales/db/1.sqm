CREATE UNIQUE INDEX IF NOT EXISTS Sale_terminal_local_unique_idx ON Sale(terminalId, localNumber);
CREATE INDEX IF NOT EXISTS Sale_shift_timestamp_idx ON Sale(shiftId, timestamp);
CREATE INDEX IF NOT EXISTS Sale_status_timestamp_idx ON Sale(status, timestamp);
CREATE UNIQUE INDEX IF NOT EXISTS SaleItem_sale_product_unique_idx ON SaleItem(saleId, productId);
CREATE INDEX IF NOT EXISTS SalePayment_sale_timestamp_idx ON SalePayment(saleId, timestamp);
CREATE INDEX IF NOT EXISTS SalePayment_status_timestamp_idx ON SalePayment(status, timestamp);
