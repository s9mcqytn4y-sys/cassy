import kotlin.Boolean;

CREATE TABLE OutboxEvent (
    id TEXT NOT NULL PRIMARY KEY,
    timestamp INTEGER NOT NULL,
    type TEXT NOT NULL,
    payload TEXT NOT NULL,
    status TEXT NOT NULL
);

CREATE TABLE AuditLog (
    id TEXT NOT NULL PRIMARY KEY,
    timestamp INTEGER NOT NULL,
    message TEXT NOT NULL,
    level TEXT NOT NULL
);

CREATE TABLE Metadata (
    key TEXT NOT NULL PRIMARY KEY,
    value TEXT NOT NULL
);

CREATE TABLE ProductCategory (
    id TEXT NOT NULL PRIMARY KEY,
    name TEXT NOT NULL,
    color TEXT NOT NULL
);

CREATE TABLE Product (
    id TEXT NOT NULL PRIMARY KEY,
    categoryId TEXT NOT NULL,
    name TEXT NOT NULL,
    price REAL NOT NULL,
    sku TEXT NOT NULL,
    imageUrl TEXT,
    isActive INTEGER AS Boolean NOT NULL DEFAULT 1,
    FOREIGN KEY(categoryId) REFERENCES ProductCategory(id)
);

CREATE TABLE ProductBarcode (
    barcode TEXT NOT NULL PRIMARY KEY,
    productId TEXT NOT NULL,
    type TEXT NOT NULL, -- 'GLOBAL', 'INTERNAL'
    FOREIGN KEY(productId) REFERENCES Product(id)
);

CREATE TABLE BusinessDay (
    id TEXT NOT NULL PRIMARY KEY,
    openedAt INTEGER NOT NULL,
    closedAt INTEGER,
    status TEXT NOT NULL -- 'OPEN', 'CLOSED'
);

CREATE TABLE Shift (
    id TEXT NOT NULL PRIMARY KEY,
    businessDayId TEXT NOT NULL,
    terminalId TEXT NOT NULL,
    openedAt INTEGER NOT NULL,
    closedAt INTEGER,
    openedBy TEXT NOT NULL,
    closedBy TEXT,
    status TEXT NOT NULL, -- 'OPEN', 'CLOSED'
    FOREIGN KEY(businessDayId) REFERENCES BusinessDay(id)
);

CREATE TABLE Sale (
    id TEXT NOT NULL PRIMARY KEY,
    localNumber TEXT NOT NULL,
    shiftId TEXT NOT NULL,
    terminalId TEXT NOT NULL,
    timestamp INTEGER NOT NULL,
    totalAmount REAL NOT NULL,
    taxAmount REAL NOT NULL,
    discountAmount REAL NOT NULL,
    finalAmount REAL NOT NULL,
    status TEXT NOT NULL, -- 'PENDING', 'COMPLETED', 'CANCELLED', 'SUSPENDED'
    suspendedAt INTEGER,
    FOREIGN KEY(shiftId) REFERENCES Shift(id)
);

CREATE TABLE SaleItem (
    id TEXT NOT NULL PRIMARY KEY,
    saleId TEXT NOT NULL,
    productId TEXT NOT NULL,
    unitPrice REAL NOT NULL,
    quantity REAL NOT NULL,
    totalPrice REAL NOT NULL,
    taxAmount REAL NOT NULL,
    discountAmount REAL NOT NULL,
    FOREIGN KEY(saleId) REFERENCES Sale(id),
    FOREIGN KEY(productId) REFERENCES Product(id)
);

CREATE TABLE SalePayment (
    id TEXT NOT NULL PRIMARY KEY,
    saleId TEXT NOT NULL,
    method TEXT NOT NULL, -- 'CASH', 'CARD', 'QRIS'
    amount REAL NOT NULL,
    status TEXT NOT NULL, -- 'PENDING', 'SUCCESS', 'FAILED'
    providerReference TEXT,
    timestamp INTEGER NOT NULL,
    FOREIGN KEY(saleId) REFERENCES Sale(id)
);

CREATE TABLE ReceiptSnapshot (
    saleId TEXT NOT NULL PRIMARY KEY,
    content TEXT NOT NULL, -- JSON or Template data
    createdAt INTEGER NOT NULL,
    FOREIGN KEY(saleId) REFERENCES Sale(id)
);

