CREATE INDEX IF NOT EXISTS OutboxEvent_status_timestamp_idx ON OutboxEvent(status, timestamp);
CREATE INDEX IF NOT EXISTS AuditLog_timestamp_idx ON AuditLog(timestamp);
CREATE INDEX IF NOT EXISTS OperatorAccount_active_role_name_idx ON OperatorAccount(isActive, role, displayName);
CREATE INDEX IF NOT EXISTS AccessSession_status_updatedAt_idx ON AccessSession(status, updatedAt);
CREATE UNIQUE INDEX IF NOT EXISTS AccessSession_active_unique_idx ON AccessSession(status) WHERE status = 'ACTIVE';
CREATE INDEX IF NOT EXISTS BusinessDay_status_openedAt_idx ON BusinessDay(status, openedAt);
CREATE UNIQUE INDEX IF NOT EXISTS BusinessDay_open_unique_idx ON BusinessDay(status) WHERE status = 'OPEN';
CREATE INDEX IF NOT EXISTS Shift_businessDay_status_openedAt_idx ON Shift(businessDayId, status, openedAt);
CREATE UNIQUE INDEX IF NOT EXISTS Shift_terminal_open_unique_idx ON Shift(terminalId) WHERE status = 'OPEN';
