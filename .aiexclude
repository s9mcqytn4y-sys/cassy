# Cassy AI Exclude V2.1 - Hardened
# Keep context useful. Remove noise, not signal.

# IDE / local
.idea/
.kotlin/
.vscode/
.DS_Store
Thumbs.db
*.iml

# Build outputs / caches
.gradle/
**/build/
out/
dist/
target/
tmp/
temp/
coverage/
reports/
.cxx/

# Logs
*.log

# Heavy binaries / packages
*.apk
*.aab
*.apks
*.jar
*.so
*.dylib
*.dll
*.exe
*.msi
*.dmg
*.app
*.ipa
*.zip
*.tar
*.gz
*.7z
*.rar

# Secrets / local credentials
local.properties
*.keystore
*.jks
*.p12
*.pem
*.key
secrets.*
google-services.json
GoogleService-Info.plist

# DB lock/shm noise
*.db-shm
*.db-wal
*.sqlite-shm
*.sqlite-wal
*.trace

# Vendor / deps
node_modules/
vendor/

# Test artifacts
screenshots/
recordings/
artifacts/
test-results/
snapshot-output/

# Documentation source (excluded if already rendered in context)
# docs/ai/**

# Intentionally NOT excluded:
# - AGENTS.md
# - CODEX.md
# - CLAUDE.md
# - GEMINI.md
# - .agent/**
# - .github/**
# - apps/**
# - shared/**
# - docs/** (Execution docs are vital signal)
# - tooling/**
# - gradle/**
# - *.md
# - settings.gradle.kts
# - build.gradle.kts
# - gradle/libs.versions.toml
# - assets/logo/** (Metadata for UI branding)
