# Cassy AI Exclude V2
# Keep context useful. Remove noise, not signal.

# IDE / local
.idea/
.kotlin/
.vscode/.history/
.DS_Store
Thumbs.db
*.iml

# Build outputs / caches
.gradle/
**/build/
out/
dist/
target/
tmp/
temp/
coverage/
reports/
.cxx/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Heavy binaries / packages
*.apk
*.aab
*.apks
*.jar
*.war
*.ear
*.so
*.dylib
*.dll
*.exe
*.msi
*.dmg
*.app
*.ipa
*.zip
*.tar
*.gz
*.7z
*.rar
*.pdf

# Secrets / local credentials
local.properties
*.keystore
*.jks
*.p12
*.pem
*.key
*.mobileprovision
.env
.env.*
secrets.*
google-services.json
GoogleService-Info.plist

# DB lock/shm noise
*.db-shm
*.db-wal
*.sqlite-shm
*.sqlite-wal
*.trace

# Vendor / deps
node_modules/
vendor/
Pods/
DerivedData/

# Test artifacts
screenshots/
recordings/
artifacts/
test-results/
snapshot-output/

# Intentionally NOT excluded:
# - AGENTS.md
# - CODEX.md
# - CLAUDE.md
# - GEMINI.md
# - .agent/**
# - .github/**
# - apps/**
# - shared/**
# - docs/**
# - tooling/**
# - gradle/**
# - *.md
