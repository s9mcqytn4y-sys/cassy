# Handle line endings automatically for files detected as text
# and leave binary files untouched.
* text=auto

# Standard patterns for common file types
*.kt text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.editorconfig text eol=lf
*.json text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.jar binary
*.zip binary
